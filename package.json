{
  "name": "pomodoro",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "APP_VARIANT=dev expo prebuild --clean --platform=ios && APP_VARIANT=dev expo run:ios --device",
    "ios:test": "APP_VARIANT=test expo prebuild --clean --platform=ios && APP_VARIANT=test expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "format": "prettier --write src",
    "test": "jest --watchAll=false --watchman=false",
    "format:changed": "bash -lc 'files=$(git diff --name-only --diff-filter=ACMRTUXB HEAD -- \"src\" | tr \"\\n\" \" \"); if [ -z \"$files\" ]; then echo \"No changed files in src\"; exit 0; fi; bunx prettier --write $files'",
    "test:changed": "jest --watchAll=false --watchman=false --onlyChanged",
    "extract": "lingui extract",
    "compile": "lingui compile --typescript"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.0",
    "@expo/ui": "~0.2.0-beta.9",
    "@lingui/core": "^5.9.1",
    "@lingui/react": "^5.9.1",
    "@sentry/react-native": "~7.2.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-glass-effect": "~0.1.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-unistyles": "^3.0.22"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^5.9.1",
    "@lingui/cli": "^5.9.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.7.4",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./node_modules/react-native-gesture-handler/jestSetup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setupTests.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "private": true
}
