{
  "name": "pomodoro",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "APP_VARIANT=dev expo prebuild --clean --platform=ios && APP_VARIANT=dev expo run:ios --device",
    "ios:test": "APP_VARIANT=test expo prebuild --clean --platform=ios && APP_VARIANT=test expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "format": "prettier --write src",
    "test": "jest --watchAll=false --watchman=false",
    "maestro:test": "maestro test -e APP_ID=de.totap.focustimer.test .maestro",
    "format:changed": "bash -lc 'files=$(git diff --name-only --diff-filter=ACMRTUXB HEAD -- \"src\" | tr \"\\n\" \" \"); if [ -z \"$files\" ]; then echo \"No changed files in src\"; exit 0; fi; bunx prettier --write $files'",
    "test:changed": "jest --watchAll=false --watchman=false --onlyChanged",
    "extract": "lingui extract",
    "compile": "lingui compile --typescript",
    "lint": "expo lint"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.0",
    "@expo/ui": "55.0.1",
    "@lingui/core": "^5.9.1",
    "@lingui/react": "^5.9.1",
    "@sentry/react-native": "~7.11.0",
    "expo": "^55.0.4",
    "expo-asset": "~55.0.8",
    "expo-audio": "~55.0.8",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-notifications": "~55.0.10",
    "expo-router": "~55.0.3",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-updates": "~55.0.12",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nitro-modules": "^0.33.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-unistyles": "^3.0.22"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^5.9.1",
    "@lingui/cli": "^5.9.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": ["./node_modules/react-native-gesture-handler/jestSetup.js"],
    "setupFilesAfterEnv": ["<rootDir>/src/test/setupTests.ts"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "private": true
}
